{
  "name": "review-bundle",
  "version": "0.1.2",
  "description": "Build code review bundles for ChatGPT 5.4 Pro, using Codex to select the most relevant repository context.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build --target=bun --outfile dist/review-bundle.js ./src/index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "package:release": "./scripts/package-release.sh",
    "prepare": "lefthook install",
    "review-bundle": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "review-bundle": "./src/index.ts"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/mustache": "^4.2.6",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.3",
    "typescript": "^5.9.3"
  }
}
