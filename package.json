{
  "name": "review-export",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build --target=bun --outfile dist/review-export.js ./src/index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "prepare": "lefthook install",
    "review-export": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "review-export": "./src/index.ts"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/mustache": "^4.2.6",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.3",
    "typescript": "^5.9.3"
  }
}
